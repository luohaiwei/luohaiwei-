.user-space {
  padding: 20rpx 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 头部信息 */
.header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #ddd;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.id, .join-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.motto {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

/* 统计信息 */
.stats {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 25rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.label {
  font-size: 24rpx;
  color: #999;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #1E90FF;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background-color: #1E90FF;
  border-radius: 3rpx;
}

/* 帖子项 */
.post-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.post-meta {
  flex: 1;
}

.post-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.post-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

/* 图片区域 */
.post-images {
  display: flex;
  overflow-x: auto;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
}

.post-img {
  width: 220rpx;
  height: 220rpx;
  border-radius: 10rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}

/* 操作按钮 */
.post-actions {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 26rpx;
  color: #666;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

.count {
  margin-left: 8rpx;
  font-size: 26rpx;
  color: #999;
}

/* 评论区域 */
.comment-area {
  background-color: #f5f5f5;
  border-radius: 10rpx;
  padding: 15rpx;
}

.comment-input {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}
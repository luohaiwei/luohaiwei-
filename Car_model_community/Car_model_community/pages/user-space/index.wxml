<view class="user-space">
  <!-- 头部信息区 -->
  <view class="header">
    <image class="avatar" src="{{userInfo.avatar}}"></image>
    <view class="user-meta">
      <text class="name">{{userInfo.name}}</text>
      <text class="id">ID: {{userInfo.userId}}</text>
      <text class="join-time">{{userInfo.joinTime}} 加入车模社</text>
      <text class="motto">{{userInfo.title}}</text>
    </view>
  </view>

  <!-- 统计信息区 -->
  <view class="stats">
    <view class="stat-item">
      <text class="num">{{userInfo.follow}}</text>
      <text class="label">关注</text>
    </view>
    <view class="stat-item">
      <text class="num">{{userInfo.fans}}</text>
      <text class="label">粉丝</text>
    </view>
    <view class="stat-item">
      <text class="num">{{userInfo.likes}}</text>
      <text class="label">获赞</text>
    </view>
    <view class="stat-item">
      <text class="num">{{userInfo.carModelCount}}</text>
      <text class="label">车模</text>
    </view>
  </view>

  <!-- 标签栏 -->
  <view class="tab-bar">
    <view 
      wx:for="{{['爱车', '想要', '笔记']}}" 
      wx:key="*this" 
      class="tab {{activeTab === item ? 'active' : ''}}" 
      data-tab="{{item}}" 
      bindtap="switchTab"
    >
      {{item}}
    </view>
  </view>

  <!-- 内容区 - 笔记 -->
  <view class="content" wx:if="{{activeTab === '笔记'}}">
    <block wx:for="{{userInfo.posts}}" wx:key="postId">
      <view class="post-item">
        <view class="post-header">
          <image class="post-avatar" src="{{userInfo.avatar}}"></image>
          <view class="post-meta">
            <text class="post-name">{{userInfo.name}}</text>
            <text class="post-time">{{item.createTime}}</text>
          </view>
        </view>

        <text class="post-title">{{item.title}}</text>
        <text class="post-desc">
          {{item.brand}} · {{item.year}} · {{item.modelNo}}
        </text>

        <view class="post-images">
          <image 
            wx:for="{{item.images}}" 
            wx:key="*this" 
            class="post-img" 
            src="{{item}}"
            mode="aspectFill"
          ></image>
        </view>

        <view class="post-actions">
          <button class="action-btn">
            <text>分享</text>
          </button>
          <button class="action-btn">
            <text>点赞</text>
            <text wx:if="{{item.likes > 0}}" class="count">{{item.likes}}</text>
          </button>
          <button class="action-btn">
            <text>评论</text>
            <text wx:if="{{item.comments > 0}}" class="count">{{item.comments}}</text>
          </button>
        </view>

        <view class="comment-area">
          <input class="comment-input" placeholder="说点什么..." />
        </view>
      </view>
    </block>
  </view>
</view>
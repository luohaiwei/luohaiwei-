/* 重置样式 */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
}

/* 搜索框样式 */
.search-container {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.search-btn {
  background-color: #1E90FF;
  color: white;
  border-radius: 30rpx;
  font-size: 28rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin-left: 10rpx;
  max-width: 200rpx;
}

/* 分类标签样式 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-tags {
  display: inline-flex;
}

.tag {
  display: inline-block;
  background-color: #fff;
  padding: 10rpx 25rpx;
  border-radius: 30rpx;
  margin-right: 15rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tag.active {
  background-color: #1E90FF;
  color: white;
}

/* 轮播图与推荐商品容器 */
.grid-container {
  display: flex;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.swiper-container, .featured-product {
  flex: 1;
  border-radius: 10rpx;
  overflow: hidden;
}

/* 轮播图样式 */
.swiper-container {
  height: 340rpx;
  background-color: #000;
}

.swiper-container swiper {
  height: 100%;
}

.swiper-container swiper-item {
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.expert-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  padding: 15rpx;
  display: flex;
  align-items: center;
}

.expert-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.expert-details {
  flex: 1;
}

.expert-name {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.expert-title {
  font-size: 24rpx;
  color: #ccc;
}

/* 推荐商品样式 */
.featured-product {
  background-color: #fff;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.featured-product-image {
  width: 100%;
  height: 120rpx;
  object-fit: cover;
}

.featured-product-info {
  padding: 15rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.featured-product-title {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.featured-product-brand {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.featured-stats {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.featured-i-have-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  align-self: flex-start;
  max-width: 200rpx;
}

/* 商品网格样式 */
.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr); 
  gap: 20rpx; 
}

.product-card {
  background: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.product-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.product-info {
  padding: 15rpx;
}

.product-title {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 72rpx;
}

.product-brand {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.product-actions {
  display: flex;
  justify-content: space-between;
}

.i-have-btn, .buy-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 0;
  margin: 0 5rpx;
  line-height: 1.4;
  border-radius: 20rpx;
  text-align: center;
}

.i-have-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
}

.buy-btn {
  background-color: #ff4d4f;
  color: white;
  border: none;
}

/* 加载更多样式 */
.load-more-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 10rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
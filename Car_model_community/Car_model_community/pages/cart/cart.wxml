<view class="cart-container">
  <!-- 购物车商品列表 -->
  <view class="cart-list">
    <view 
      wx:for="{{cartItems}}" 
      wx:key="id" 
      class="cart-item"
    >
      <!-- 商品信息 -->
      <view class="item-info">
        <!-- 新增图片容器，用于控制图片显示模式 -->
        <view class="img-container">
          <image 
            class="item-img" 
            src="{{item.imageUrl}}"
            mode="aspectFill"
          ></image>
        </view>
        <view class="item-desc">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">¥{{item.price}}</text>
        </view>
      </view>
      <!-- 数量操作 + 删除按钮 -->
      <view class="item-ops">
        <view class="num-ops">
          <text 
            class="num-op" 
            bindtap="decreaseQuantity" 
            data-index="{{index}}"
          >-</text>
          <text class="num">{{item.quantity}}</text>
          <text 
            class="num-op" 
            bindtap="increaseQuantity" 
            data-index="{{index}}"
          >+</text>
        </view>
        <text 
          class="delete-btn" 
          bindtap="deleteItem" 
          data-index="{{index}}"
        >删除</text>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="cart-footer">
    <view class="total-price">
      <text>合计: </text>
      <text class="price">¥{{totalPrice}}</text>
    </view>
    <button class="checkout-btn" bindtap="checkout">结算</button>
  </view>
</view>
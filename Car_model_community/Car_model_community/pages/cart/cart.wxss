/* 购物车容器 */
.cart-container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 商品列表 */
.cart-list {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

/* 单个商品项 */
.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

/* 商品信息区域 */
.item-info {
  display: flex;
  align-items: center;
}
/* 图片容器：控制图片显示区域，避免拉伸 */
.img-container {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 20rpx;
}
.item-img {
  width: 100%;
  height: 100%;
}
.item-desc {
  display: flex;
  flex-direction: column;
}
.item-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}
.item-price {
  font-size: 28rpx;
  color: #e64340;
}

/* 数量操作 + 删除区域 */
.item-ops {
  display: flex;
  align-items: center;
}
.num-ops {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  border: 1rpx solid #ccc;
  border-radius: 8rpx;
  overflow: hidden;
}
.num-op {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #f5f5f5;
  font-size: 36rpx;
  color: #666;
}
.num {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}
.delete-btn {
  font-size: 28rpx;
  color: #e64340;
}

/* 底部结算栏 */
.cart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
}
.total-price {
  font-size: 32rpx;
  color: #333;
}
.price {
  color: #e64340;
  font-weight: bold;
}
.checkout-btn {
  background-color: #e64340;
  color: #fff;
  font-size: 32rpx;
  padding: 16rpx 40rpx;
  border-radius: 8rpx;
}
/* pages/car-detail/index.wxss */
page {
  height: 100%;
  background-color: #f8f8f8;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 内容区域 */
.content-wrapper {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 120rpx; /* 为底部按钮留出空间 */
}

/* 顶部图片区域 */
.car-header {
  position: relative;
  width: 100%;
  height: 500rpx;
  overflow: hidden;
}

.car-big-image {
  width: 100%;
  height: 100%;
}

/* 基本信息区域 */
.car-basic-info {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-label {
  width: 120rpx;
  color: #666;
  font-size: 28rpx;
}

.info-value {
  flex: 1;
  color: #333;
  font-size: 28rpx;
  font-weight: 500;
}

.out-of-stock {
  color: #ff5500;
}

/* 描述区域 */
.car-description {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #e4393c;
  padding-left: 20rpx;
}

.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  padding: 30rpx;
  background-color: #fff;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.have-button, .buy-button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  margin: 0 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
}

.have-button {
  background-color: #f5f5f5;
  color: #333;
}

.buy-button {
  background-color: #ff5500;
  color: #fff;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}
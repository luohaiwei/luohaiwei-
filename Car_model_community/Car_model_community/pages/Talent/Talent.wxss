.talent-container {
  padding: 16px;
  background-color: #fff;
}

.tab-bar {
  display: flex;
  border-bottom: 1px solid #f5f5f5;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 16px;
  color: #333;
}

.tab.active {
  color: #ff5722;
  border-bottom: 2px solid #ff5722;
}

.talent-list {
  margin-top: 16px;
}

.talent-item {
  padding: 16px;
  border-bottom: 1px solid #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
}

.follow-btn {
  padding: 6px 12px;
  font-size: 14px;
  border-radius: 20px;
}

.follow-btn.followed {
  background-color: #ff5722;
  color: #fff;
  border: none;
}

.info {
  margin-top: 8px;
}

.name {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.desc {
  font-size: 14px;
  color: #666;
  margin-top: 4px;
}

.stats {
  display: flex;
  gap: 16px;
  margin-top: 8px;
  font-size: 14px;
  color: #999;
}

.post-preview {
  display: flex;
  align-items: center;
  margin-top: 12px;
}

.post-img {
  width: 80px;
  height: 80px;
  margin-right: 12px;
  border-radius: 8px;
}

.post-info {
  flex: 1;
}

.post-title {
  font-size: 16px;
  color: #333;
  line-height: 1.4;
}

.post-meta {
  font-size: 14px;
  color: #999;
  margin-top: 4px;
}
<view class="container">
  <!-- 主体布局（分类+商品列表） -->
  <view class="main-layout">
    <!-- 左侧分类栏（可滚动） -->
    <scroll-view class="category-list" scroll-y>
      <view 
        class="category-item {{currentCategory === 0 ? 'active' : ''}}" 
        bindtap="switchCategory" 
        data-id="0"
      >
        <text class="category-name">全部</text>
      </view>
      <view 
        class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="switchCategory" 
        data-id="{{item.id}}"
      >
        <text class="category-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧商品列表（可滚动）-保持布局逻辑 -->
    <scroll-view class="product-list" scroll-y>
      <view class="product-single-column">
        <view 
          class="product-item" 
          wx:for="{{filteredProducts}}" 
          wx:key="id"
          bindtap="viewGoodsDetail"
          data-id="{{item.id}}"
        >
          <!-- 商品图片容器（用于定位标签） -->
          <view class="image-container">
            <!-- 商品图片， mode属性显示 -->
            <image class="product-img" src="{{item.image}}" mode="aspectFill"></image>
          </view>
          
          <!-- 商品信息 -->
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <view class="price-container">
              <text class="product-price">¥{{item.price}}</text>
              <button 
                class="buy-btn" 
                bindtap="buyProduct" 
                data-id="{{item.id}}"
              >购买</button>
            </view>
          </view>
        </view>
      </view>
      <!-- 加载提示 -->
      <view class="load-more" wx:if="{{!hasMore}}">
        <text>没有更多内容了</text>
      </view>
    </scroll-view>
  </view>
</view>
/* 全局样式 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh; /* 调整为100vh，适配页面高度，避免过多空白 */
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
}

/* 主体布局（分类+商品列表） */
.main-layout {
  display: flex;
  flex: 1; /* 让主体布局占据container剩余空间 */
}

/* 左侧分类栏 */
.category-list {
  width: 160rpx;
  background-color: #ffffff;
  border-right: 1px solid #eaeaea;
  height: 100%;
  position: fixed; 
  top: 0;
  left: 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #f5f5f5;
  background-color: #fff;
  box-sizing: border-box;
  height: 150rpx;
}

.active {
  background-color: #fff0f0;
  border-left: 6rpx solid #e64340;
}

.category-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  padding: 0 10rpx;
  line-height: 1.4;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  height: 100%;
  background-color: #f5f5f5;
  margin-left: 160rpx; 
}

.product-item {
  display: flex;
  flex-direction: column;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  position: relative;
  height: 420rpx;
}

/* 图片容器 */
.image-container {
  position: relative;
  width: 100%;
  height: 280rpx;
  background-color: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
}

.product-img {
  width: 100%;
  height: 100%;
  object-fit: contain; 
}

.product-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 36rpx;
  height: 72rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 20rpx;
}

.price-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.product-price {
  font-size: 32rpx;
  color: #e64340;
  font-weight: bold;
}

.buy-btn {
  min-width: 120rpx;
  max-width: 140rpx;
  width: auto !important;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center; 
  font-size: 26rpx;
  color: #fff ;
  background-color: #e64340;
  border-radius: 28rpx;
  border: none;
  margin: 0 !important;
  padding: 0 ;
}

.buy-btn::after {
  border: none !important;
}

/* 移除按钮边框 */
.buy-btn::after {
  border: none;
}
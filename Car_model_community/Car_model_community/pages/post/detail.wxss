.container {
  padding: 20rpx;
  background-color: #fff;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.post-header {
  margin-bottom: 20rpx;
}

.post-image {
  width: 100%;
  border-radius: 16rpx;
}

.post-title {
  font-size: 40rpx;
  font-weight: bold;
  margin: 20rpx 0;
  display: block;
  color: #333;
}

.author-info {
  font-size: 28rpx;
  color: #666;
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.publish-time {
  color: #999;
}

.post-content {
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 30rpx;
}

.post-stats {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  color: #666;
  font-size: 28rpx;
}

.stat-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

.divider {
  height: 2rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

.comment-section {
  margin-top: 30rpx;
}

.comment-header {
  margin-bottom: 20rpx;
}

.comment-title {
  font-size: 32rpx;
  font-weight: bold;
}

.comment-item {
  display: flex;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
}

.comment-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-author {
  font-size: 30rpx;
  font-weight: bold;
}

.comment-time {
  font-size: 26rpx;
  color: #999;
}

.comment-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
}

.no-more-comments {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 固定在底部的操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  padding: 15rpx 0;
  z-index: 100;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
}

.action-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 10rpx;
}
<view class="container">
  <!-- 帖子头部 -->
  <view class="post-header">
    <block wx:if="{{post.video}}">
      <video src="{{post.video}}" poster="{{post.image}}" mode="aspectFill"></video>
    </block>
    <block wx:else>
      <image src="{{post.image || '/images/car2.jpg'}}" class="post-image" mode="widthFix" />
    </block>
    <text class="post-title">{{post.title || '无标题'}}</text>
  </view>
  
  <!-- 作者信息 -->
  <view class="author-info">
    <text>作者: {{post.author || '未知作者'}}</text>
    <text class="publish-time">{{post.publishTime || '未知时间'}}</text>
  </view>
  
  <!-- 帖子内容 -->
  <view class="post-content">
    <text user-select>{{post.content || '无内容'}}</text>
  </view>
  
  <!-- 互动统计 -->
  <view class="post-stats">
    <view class="stat-item">点赞<text>{{post.likes || 0}}</text></view>
    <view class="stat-item">评论<text>{{comments.length || 0}}</text></view>
    <view class="stat-item">转发<text>{{post.shares || 0}}</text></view>
  </view>
  
  <!-- 分割线 -->
  <view class="divider"></view>
  
  <!-- 评论区 -->
  <view class="comment-section">
    <view class="comment-header">
      <text class="comment-title">共{{comments.length}}条评论</text>
    </view>
    
    <view class="comment-list">
      <view class="comment-item" wx:for="{{comments}}" wx:key="id">
        <image src="{{item.avatar || '/images/avatar/avatar3.png'}}" class="comment-avatar" />
        <view class="comment-content">
          <view class="comment-header">
            <text class="comment-author">{{item.author || '匿名用户'}}</text>
            <text class="comment-time">{{item.time || '未知时间'}}</text>
          </view>
          <text class="comment-text">{{item.content || '无内容'}}</text>
        </view>
      </view>
    </view>
    
    <!-- 没有更多评论提示 -->
    <view class="no-more-comments">
      <text>已经到底了</text>
    </view>
  </view>
  
  <!-- 评论输入框 -->
  <view class="comment-input-box" wx:if="{{showCommentInput}}">
    <input type="text" placeholder="请输入评论内容" bindinput="onCommentInput" value="{{commentContent}}" />
    <button bindtap="submitComment">提交</button>
    <button bindtap="cancelComment">取消</button>
  </view>
  
  <!-- 操作按钮 - 固定在底部 -->
  <view class="action-buttons">
    <view class="action-item" bindtap="likePost">
      <text>点赞</text>
    </view>
    <view class="action-item" bindtap="focusComment">
      <text>评论</text>
    </view>
    <button class="action-item" open-type="share">
      <text>分享</text>
    </button>
  </view>
</view>
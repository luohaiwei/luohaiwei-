.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 表单容器 */
.form-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.form-input {
  height: 90rpx;
  background-color: #f5f5f5;
  border-radius: 15rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.picker-view {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.arrow-down {
  width: 30rpx;
  height: 30rpx;
}

.submit-btn {
  margin-top: 60rpx;
  background-color: #1E90FF;
  color: #fff;
  border-radius: 12rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center; 
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
  border: none; 
}

/* 查看车库按钮 */
.view-garage-btn {
  margin-top: 30rpx;
  text-align: center;
  color: #1E90FF;
  font-size: 28rpx;
  padding: 20rpx 0;
}

/* 车库内容区域 */
.garage-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background-color: #1E90FF;
  color: #fff;
  font-size: 28rpx;
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 30rpx;
  border-radius: 35rpx;
  margin: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.add-first-btn {
  background-color: #1E90FF;
  color: #fff;
  width: 60%;
  height: 90rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
}

/* 车模列表 */
.car-model-list {
  display: flex;
  flex-direction: column;
}

.car-model-card {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
  align-items: center;
}

.car-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  margin-right: 30rpx;
  background-color: #f5f5f5;
}

.car-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 200rpx;
}

.car-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.car-brand {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.car-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.car-number {
  font-size: 26rpx;
  color: #999;
}

.car-year {
  font-size: 26rpx;
  color: #999;
}
/* 图片上传区域 */
.image-upload {
  width: 100%;
  height: 300rpx;
  background-color: #f9f9f9;
  border-radius: 15rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  border: 2rpx dashed #ddd;
}
.uploaded-image {
  width: 100%;
  height: 100%;
}
.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.camera-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}
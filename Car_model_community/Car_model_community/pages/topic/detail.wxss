/* 页面容器 */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 话题头部 */
.topic-header {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.topic-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.topic-meta {
  display: flex;
  justify-content: space-between;
  color: #666;
  font-size: 28rpx;
}

.topic-date {
  color: #1E90FF;
}

.topic-participants {
  background-color: #f0f8ff;
  padding: 6rpx 15rpx;
  border-radius: 20rpx;
}

/* 话题描述 */
.topic-description {
  padding: 30rpx 0;
  font-size: 32rpx;
  line-height: 1.6;
  color: #555;
  border-bottom: 1rpx solid #eee;
}

/* 分割线 */
.divider {
  height: 20rpx;
  background-color: #f0f0f0;
  margin: 30rpx -30rpx;
}

/* 帖子网格 */
.posts-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.post-item {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.post-image {
  width: 100%;
  height: 280rpx;
  display: block;
}

.post-info {
  padding: 20rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-author {
  font-size: 28rpx;
  color: #666;
}

.post-likes {
  display: flex;
  align-items: center;
  color: #ff6b6b;
  font-size: 26rpx;
}

.like-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
}
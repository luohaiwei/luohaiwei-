<view class="container">
  <!-- 话题头部 -->
  <view class="topic-header">
    <text class="topic-title">{{topic.title}}</text>
    <view class="topic-meta">
      <text class="topic-date">{{topic.dateRange}}</text>
      <text class="topic-participants">{{topic.participants}}人已参与</text>
    </view>
  </view>
  
  <!-- 话题描述 -->
  <view class="topic-description">
    <text>{{topic.description}}</text>
  </view>
  
  <!-- 分割线 -->
  <view class="divider"></view>
  
  <!-- 帖子网格 -->
  <view class="posts-grid">
    <view 
      class="post-item" 
      wx:for="{{posts}}" 
      wx:key="id"
      bindtap="onPostTap"
      data-id="{{item.id}}"
    >
      <image src="{{item.image}}" class="post-image" mode="aspectFill" />
      <view class="post-info">
        <text class="post-title">{{item.title}}</text>
        <view class="post-meta">
          <text class="post-author">{{item.author}}</text>
          <view class="post-likes">

            <text>{{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
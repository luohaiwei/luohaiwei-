<view class="car-model-card" bindtap="onTap">
  <image class="car-image" src="{{carModel.imageUrl}}" mode="aspectFill"></image>
  <view class="info">
    <text class="name">{{carModel.name}}</text>
    <text class="brand">{{carModel.brand}}</text>
    <view class="price">
      <text class="current-price">¥{{carModel.price.toFixed(2)}}</text>
      <text class="original-price">¥{{carModel.originalPrice.toFixed(2)}}</text>
    </view>
  </view>
  <view class="collect-btn" bindtap="onCollectTap" catchtap="stopPropagation">
    <image 
      src="{{carModel.collected ? '/images/collected.png' : '/images/collect.png'}}" 
      mode="aspectFit"
    ></image>
  </view>
</view>